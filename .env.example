# Pixel Office Agent Environment Variables
# Copy this file to .env and uncomment variables as needed.
# .env is gitignored and loaded automatically by the F5 launch config.

# Enable verbose debug logging for hook events (SessionStart, SessionEnd, Stop, etc.)
PIXEL_AGENTS_DEBUG=1

# Host/port used by compose.yaml. Keep the application port at 3100 unless the
# hook configuration is updated to match.
PIXEL_OFFICE_BIND=0.0.0.0
PIXEL_OFFICE_PORT=3100

# Bearer token required for hook event endpoints. If unset, auth is skipped (dev mode).
# PIXEL_OFFICE_HOOK_TOKEN=your-random-token-here
